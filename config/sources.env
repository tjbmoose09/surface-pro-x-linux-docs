# Upstream sources used by the starter tooling.

SPX_KERNEL_REPO="${SPX_KERNEL_REPO:-https://github.com/linux-surface/kernel.git}"
SPX_KERNEL_REF="${SPX_KERNEL_REF:-spx/v6.18}"

SPX_CONFIG_REPO="${SPX_CONFIG_REPO:-https://github.com/qzed/aarch64-kernel-configs.git}"
SPX_CONFIG_REF="${SPX_CONFIG_REF:-dc7be78b3d59f23405d4b49aae4c0c31123fcb10}"

SPX_AARCH64_FIRMWARE_REPO="${SPX_AARCH64_FIRMWARE_REPO:-https://github.com/linux-surface/aarch64-firmware.git}"
SPX_AARCH64_FIRMWARE_REF="${SPX_AARCH64_FIRMWARE_REF:-main}"

SPX_AARCH64_PACKAGES_REPO="${SPX_AARCH64_PACKAGES_REPO:-https://github.com/linux-surface/aarch64-packages.git}"
SPX_AARCH64_PACKAGES_REF="${SPX_AARCH64_PACKAGES_REF:-main}"

SPX_ARCH_MKIMG_REPO="${SPX_ARCH_MKIMG_REPO:-https://github.com/linux-surface/aarch64-arch-mkimg.git}"
SPX_ARCH_MKIMG_REF="${SPX_ARCH_MKIMG_REF:-main}"

SPX_GRUB_IMAGE_REPO="${SPX_GRUB_IMAGE_REPO:-https://github.com/linux-surface/grub-image-aarch64.git}"
SPX_GRUB_IMAGE_REF="${SPX_GRUB_IMAGE_REF:-main}"
