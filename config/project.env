# Shared project defaults. Scripts source this file through scripts/lib/common.sh.

SPX_BUILD_DIR="${SPX_BUILD_DIR:-${SPX_REPO_ROOT}/build}"
SPX_SRC_DIR="${SPX_SRC_DIR:-${SPX_BUILD_DIR}/src}"
SPX_ARTIFACT_DIR="${SPX_ARTIFACT_DIR:-${SPX_BUILD_DIR}/artifacts}"
SPX_LOG_DIR="${SPX_LOG_DIR:-${SPX_BUILD_DIR}/logs}"
SPX_MANIFEST_DIR="${SPX_MANIFEST_DIR:-${SPX_BUILD_DIR}/manifests}"

SPX_KERNEL_BUILD_DIR="${SPX_KERNEL_BUILD_DIR:-${SPX_BUILD_DIR}/kernel-build}"
SPX_KERNEL_ARTIFACT_DIR="${SPX_KERNEL_ARTIFACT_DIR:-${SPX_ARTIFACT_DIR}/kernel}"
SPX_FIRMWARE_OUT="${SPX_FIRMWARE_OUT:-${SPX_ARTIFACT_DIR}/firmware}"
SPX_BOOT_TREE_DIR="${SPX_BOOT_TREE_DIR:-${SPX_ARTIFACT_DIR}/boot-tree}"

SPX_ARCH="${SPX_ARCH:-arm64}"
SPX_CROSS_COMPILE="${SPX_CROSS_COMPILE:-aarch64-linux-gnu-}"
SPX_QEMU_MEMORY="${SPX_QEMU_MEMORY:-4096}"
SPX_QEMU_CPUS="${SPX_QEMU_CPUS:-4}"
SPX_QEMU_TIMEOUT="${SPX_QEMU_TIMEOUT:-180}"
